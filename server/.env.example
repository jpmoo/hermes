# Hermes Server — copy to .env and set values
PORT=3000
NODE_ENV=production

# PostgreSQL (headless Ubuntu server)
DATABASE_URL=postgresql://hermes:your_password@localhost:5432/hermes

# JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Ollama (embeddings, semantic search, autotagging)
OLLAMA_URL=http://localhost:11434
# Model for note embeddings (e.g. nomic-embed-text). Used for semantic search, Regions view, duplicate detection.
OLLAMA_EMBED_MODEL=nomic-embed-text
# Nomic: set to 1 so notes use search_document: and queries use search_query: (better semantic search).
# After enabling, run once: npm run reembed
# HERMES_EMBED_NOMIC_PREFIXES=1
# HERMES_EMBED_LEGACY_PLAIN=1
# Model for AI tag proposals and other light LLM calls (e.g. mistral, llama3.2).
OLLAMA_TAG_MODEL=mistral

# Optional: default JWT for Streamable HTTP MCP when clients omit Authorization (same token as web login)
# HERMES_MCP_TOKEN=

# Optional: base URL for MCP→API calls (default http://127.0.0.1:$PORT)
# HERMES_INTERNAL_API_URL=http://127.0.0.1:3000
# Optional: public API base shown in MCP hermes_attachment_upload_help (e.g. https://home.ts.net/hermes)
# HERMES_PUBLIC_API_URL=https://your-host/hermes

# Optional: RAGDoll HTTP API (Stream “RAG documents” panel for allowed usernames only)
# RAGDOLL_BASE_URL=http://localhost:9042
# Or host + port (used if RAGDOLL_BASE_URL is unset):
# RAGDOLL_HOST=localhost
# RAGDOLL_PORT=9042
# Comma-separated collection names; omit to search all collections on RAGDoll
# RAGDOLL_COLLECTIONS=edleadership,reports
# Optional similarity threshold forwarded to RAGDoll (omit to use RAGDoll server default)
# RAGDOLL_QUERY_THRESHOLD=0.45
# Comma-separated Hermes usernames allowed to see the panel (unset → jpmoo only; set to empty → no one)
# RAGDOLL_ENABLED_USERNAMES=jpmoo
