[Unit]
Description=Hermes Personal Knowledge Messenger
After=network.target postgresql.service

[Service]
Type=simple
User=hermes
Group=hermes
WorkingDirectory=/hermes/server
Environment=NODE_ENV=production
EnvironmentFile=/hermes/server/.env
ExecStart=/usr/bin/node src/index.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
