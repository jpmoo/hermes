{
  "name": "hermes",
  "version": "0.1.0",
  "private": true,
  "description": "Hermes — Personal Knowledge Messenger",
  "scripts": {
    "install:all": "npm install && cd server && npm install && cd ../app && npm install && cd ../client && npm install",
    "build": "cd app && npm run build",
    "build:client": "cd client && npm run build",
    "start": "cd server && npm start",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:app\"",
    "dev:server": "cd server && npm run dev",
    "dev:app": "cd app && npm run dev",
    "dev:client": "cd client && npm run dev",
    "db:migrate": "cd server && npm install && npm run db:migrate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
